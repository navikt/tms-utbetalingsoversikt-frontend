---
import { fetchDecoratorReact } from "@navikt/nav-dekoratoren-moduler/ssr";
import { getDecoratorEnvironment } from "../utils/server/environment";
import styles from "./Layout.module.css";
import "./index.css";

interface Props {
  title?: string;
}

const { title = "Mine utbetalinger - nav.no" } = Astro.props;

const Decorator = await fetchDecoratorReact({
  env: getDecoratorEnvironment(),
  params: {
    context: "privatperson",
  },
});
console.log(title);
---

<!doctype html>
<html lang="nb">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link
      rel="preload"
      href="https://cdn.nav.no/aksel/@navikt/ds-css/6.16.2/index.min.css"
      as="style"
    />
    <link
      rel="stylesheet"
      href="https://cdn.nav.no/aksel/@navikt/ds-css/6.16.2/index.min.css"
    />
    <Decorator.HeadAssets />
  </head>
  <body class="page-wrapper">
    <a class={styles.skipLink} href="#main-content">Hopp til hovedinnhold</a>
    <Decorator.Header />
    <div class={styles.pageWrapper}>
      <main id="main-content" tabindex="-1" class={styles.pageContainer}>
        <slot />
      </main>
    </div>
    <Decorator.Footer />
    <Decorator.Scripts />
  </body>
</html>
